# Polymarket private key.
# Required to create API credentials on first run and to place live orders.
POLYMARKET_PRIVATE_KEY=0xyour_private_key

# Polymarket proxy wallet address.
# Required for position sync, balance checks, and claim operations.
POLYMARKET_PROXY_ADDRESS=0xyour_proxy_wallet_address

# App mode.
# full = web UI + API
# headless = API only
APP_MODE=full

# Master switch for live trading.
# Keep this false until wallet, auth, and risk controls are verified.
LIVE_TRADING_ENABLED=false

# Auto claim switch.
AUTO_CLAIM_ENABLED=true

# Strategy config.
# All strategies are disabled by default.
STRATEGY_S1_ENABLED=false
STRATEGY_S1_AMOUNT=1
STRATEGY_S2_ENABLED=false
STRATEGY_S2_AMOUNT=1
STRATEGY_S3_ENABLED=false
STRATEGY_S3_AMOUNT=1
STRATEGY_S4_ENABLED=false
STRATEGY_S4_AMOUNT=1
STRATEGY_S5_ENABLED=false
STRATEGY_S5_AMOUNT=1

# Default order slippage.
ORDER_DEFAULT_SLIPPAGE=0.05

# Optional outbound proxy override for market/price/orderbook requests.
# Use an HTTP proxy URL here when your shell has stale proxy env vars.
# NOTE: If this is not set, the system will clear HTTPS_PROXY/HTTP_PROXY env vars
#       to prevent "400 The plain HTTP request was sent to HTTPS port" errors with ClobClient.
# APP_PROXY_URL=http://127.0.0.1:10808

# Security settings.
# APP_API_TOKEN can be set to a custom value, or `auto` to derive it from the private key.
APP_BIND_HOST=127.0.0.1
APP_API_TOKEN=auto
